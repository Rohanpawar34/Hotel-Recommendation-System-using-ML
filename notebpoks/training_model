## The Silhouette Score is a metric used to evaluate the quality of clustering algorithms such as K-Means. 
## It tells you how well the data points are grouped into clusters.

### Projct Title: Hotel Recommendation System USing Machine Learning.
### Problem Statements in Hotel Recommendation System:
### Helping Users to find their perfect budget friendly Hotels 
### Providing a list of hotels to users based on their budget and rating preferences.


import pandas as pd
import pickle
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import silhouette_score

# Load dataset
df = pd.read_csv("hotels.csv")
df.columns = df.columns.str.strip()

# Clean Price column
df["Price"] = (
    df["Price"]
    .astype(str)
    .str.extract(r'(\d+)')
    .astype(float)
)

df["Price"] = df["Price"].fillna(df["Price"].median())

# Select features
X = df[["Price", "Rating"]]

# Scale the data
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

best_score = 0
best_model = None
best_k = 0

# Trying  different values of K
for k in range(2, 8):
    model = KMeans(n_clusters=k,random_state=42,n_init=10)

    labels = model.fit_predict(X_scaled)
    score = silhouette_score(X_scaled, labels)

    print("K =", k)
    print("Silhouette Score =", round(score, 3))
    print()

    if score > best_score:
        best_score = score
        best_model = model
        best_k = k

# Save model
pickle.dump(best_model, open("model.pkl", "wb"))
pickle.dump(scaler, open("scaler.pkl", "wb"))

print("--------------------------------")
print("Best Number of Clusters :", best_k)
print("Best Silhouette Score   :", round(best_score, 3))
print("Model Saved Successfully")
print("--------------------------------")



